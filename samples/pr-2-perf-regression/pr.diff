+/**
+ * GET /api/users/search?q=searchTerm
+ * Search users by name or email and return with their open task counts
+ */
+router.get('/search', async (req, res) => {
+  try {
+    const { q } = req.query;
+    
+    if (!q) {
+      return res.status(400).json({ error: 'Search query parameter "q" is required' });
+    }
+
+    // Fetch all users from database
+    const usersResult = await pool.query('SELECT * FROM users');
+    const allUsers = usersResult.rows;
+
+    // Filter users in JavaScript
+    const matchingUsers = allUsers.filter(user => {
+      return user.name.toLowerCase().includes(q.toLowerCase()) || 
+             user.email.toLowerCase().includes(q.toLowerCase());
+    });
+
+    // Get task count for each user
+    const usersWithTaskCounts = [];
+    for (const user of matchingUsers) {
+      const taskCountResult = await pool.query(
+        'SELECT COUNT(*) FROM tasks WHERE user_id = $1 AND status = $2',
+        [user.id, 'open']
+      );
+      
+      usersWithTaskCounts.push({
+        id: user.id,
+        name: user.name,
+        email: user.email,
+        openTaskCount: parseInt(taskCountResult.rows[0].count)
+      });
+    }
+
+    const responseData = JSON.stringify(usersWithTaskCounts);
+    res.json(JSON.parse(responseData));
+  } catch (error) {
+    res.status(500).json({ error: 'Internal server error' });
+  }
+});
+
 module.exports = router;

